# Xcode project is generated by xcodegen from project.yml — run `xcodegen` after cloning.
*.xcodeproj
*.xcworkspace

# Xcode
DerivedData/
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Packages/*/Package.resolved

# macOS
.DS_Store

# Simulator / device logs
*.crash

# Fastlane / CI artifacts
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# Fastlane secrets — never commit signing/API credentials
fastlane/*.p8
fastlane/*.p12
fastlane/*.mobileprovision
fastlane/.env
fastlane/.env.*
*.cer
*.p12
